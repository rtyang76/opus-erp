# ===================================
# Opus ERP .gitignore
# ===================================

# ==================== Java / Maven ====================

# 编译产物
**/target/
*.class
*.jar
*.war
*.ear

# Maven
.mvn/
mvnw
mvnw.cmd

# IDE 文件
.idea/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.factorypath
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# 日志
*.log
logs/
log/

# 临时文件
*.tmp
*.temp
*.bak
*.swp
*~

# 调试文件
.dbg/
debug-*.md
jstack*.txt
*.env.local

# ==================== Node.js / Vue ====================

# 依赖
node_modules/
.pnp
.pnp.js

# 构建产物
dist/
dist-ssr/
*.local

# 缓存
.vite/
.eslintcache
.stylelintcache

# 自动生成的类型声明
auto-imports.d.ts
components.d.ts

# Vite 临时文件
*.timestamp-*.mjs

# 编辑器目录和文件
.editorconfig
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 测试覆盖率
coverage/
.nyc_output/

# Playwright
test-results/
playwright-report/
blob-report/

# ==================== 环境配置 ====================

# 环境变量文件（包含密码/密钥）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
application-dev.yml
application-prod.yml
application-local.yml

# Docker
docker-compose.override.yml

# ==================== 操作系统 ====================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.Trash-*

# ==================== 数据库 ====================

# SQL Server
*.mdf
*.ldf
*.ndf

# Redis
dump.rdb
appendonly.aof

# ==================== 工具 ====================

# Claude Code
.claude/conversations/

# Git
*.orig

# 文档构建
docs/_build/
site/
